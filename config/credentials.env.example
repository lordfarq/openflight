# Grafana Cloud Loki Credentials for OpenFlight
#
# Copy this file to /etc/alloy/credentials.env and fill in your values.
#
# To get these values:
# 1. Log in to Grafana Cloud (grafana.com)
# 2. Go to your stack -> Connections -> Loki
# 3. Click "Details" to see endpoint, user, and generate an API key
#
# IMPORTANT: Keep this file secure (chmod 600)

# Loki Push Endpoint URL
# Format: https://logs-prod-<region>.grafana.net/loki/api/v1/push
LOKI_URL=

# Grafana Cloud Instance ID (numeric, shown as "User" in Loki details)
LOKI_USER=

# API Key with logs:write scope
LOKI_API_KEY=
